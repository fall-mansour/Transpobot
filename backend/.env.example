# TranspoBot - Variables d'environnement
# 
# INSTRUCTIONS: Copier ce fichier en .env et remplir vos données

# ============================================================
# Base de données MySQL
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=transpobot
DB_PASSWORD=transpobot_pass
DB_NAME=transpobot

# ============================================================
# API OpenAI (optionnel mais recommandé)
# ============================================================
# Obtenez votre clé gratuite sur: https://platform.openai.com/account/api-keys
# Sans clé: l'app marche en mode DÉMO
OPENAI_API_KEY=sk-

# ============================================================
# Configuration du serveur
# ============================================================
PORT=8000
